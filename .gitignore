# Dependencies
node_modules/

# Build and test outputs
dist/
coverage/

# Runtime and package-manager logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment files and secrets
.env
.env.*
!.env.example

# Tool caches
.vite/
.cache/

# Operating-system files
.DS_Store
Thumbs.db

# Graphify's portable handoff artifacts are intentional. Local interpreters,
# caches, dated scratch snapshots, and machine-specific metadata stay local.
graphify-out/*
!graphify-out/GRAPH_REPORT.md
!graphify-out/graph.json
!graphify-out/graph.html
!graphify-out/cost.json
!graphify-out/manifest.json
!graphify-out/memory/
!graphify-out/memory/**
!graphify-out/reflections/
!graphify-out/reflections/**
